# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_OWNER_ID=your_telegram_chat_id
OPENAI_API_KEY=sk-your-openai-key

# === OPTIONAL — AI ===
MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=

# === OPTIONAL — Platform ===
# Auto-detected. Override if needed:
# CHROMIUM_PATH=/path/to/chrome
# SHELL_PATH=/bin/bash
# TIMEZONE=America/New_York

# === OPTIONAL — Memory (mem0) ===
# MEM0_ENABLED=true
# MEM0_URL=http://localhost:8080
# MEM0_API_KEY=

# === OPTIONAL — Browser ===
# PROXY_URL=http://proxy:port

# === OPTIONAL — Calendar ===
# GOOGLE_CALENDAR_ID=primary
